<!DOCTYPE html>
<html lang="fr">

<head>
<meta charset="UTF-8">
<title>WarehouseOps V1.0</title>

<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

<style>

body{
font-family: Arial;
background:#f4f6f9;
margin:0;
padding:0;
}

header{
background:#2c3e50;
color:white;
padding:20px;
text-align:center;
font-size:24px;
}

.container{
padding:20px;
}

.kpi-grid{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:30px;
}

.kpi{
background:white;
padding:20px;
border-radius:8px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
text-align:center;
}

.kpi h2{
margin:0;
font-size:32px;
color:#2c3e50;
}

.kpi p{
margin:5px;
color:#777;
}

table{
width:100%;
border-collapse:collapse;
background:white;
}

th,td{
padding:10px;
border-bottom:1px solid #ddd;
font-size:14px;
}

th{
background:#34495e;
color:white;
}

.status-ok{
color:green;
font-weight:bold;
}

.status-risk{
color:red;
font-weight:bold;
}

.status-surstock{
color:orange;
font-weight:bold;
}

.upload{
margin-bottom:20px;
}

</style>
</head>

<body>

<header>
WarehouseOps Dashboard V1.0
</header>

<div class="container">

<div class="upload">
<input type="file" id="excelFile"/>
</div>

<div class="kpi-grid">

<div class="kpi">
<h2 id="totalSKU">0</h2>
<p>Total SKU</p>
</div>

<div class="kpi">
<h2 id="rupture">0</h2>
<p>Articles en rupture</p>
</div>

<div class="kpi">
<h2 id="surstock">0</h2>
<p>Surstock</p>
</div>

<div class="kpi">
<h2 id="commandes">0</h2>
<p>À commander</p>
</div>

</div>

<table id="inventoryTable">

<thead>

<tr>
<th>SKU</th>
<th>Description</th>
<th>Catégorie</th>
<th>Stock</th>
<th>Reorder Point</th>
<th>EOQ</th>
<th>Status</th>
<th>Quantité suggérée</th>
</tr>

</thead>

<tbody>

</tbody>

</table>

</div>

<script>

const fileInput = document.getElementById('excelFile')

fileInput.addEventListener('change', handleFile)

function handleFile(e){

const file = e.target.files[0]
const reader = new FileReader()

reader.onload = function(evt){

const data = new Uint8Array(evt.target.result)
const workbook = XLSX.read(data,{type:'array'})
const sheet = workbook.Sheets[workbook.SheetNames[0]]

const json = XLSX.utils.sheet_to_json(sheet)

processData(json)

}

reader.readAsArrayBuffer(file)

}

function processData(data){

let rupture=0
let surstock=0
let commandes=0

const tableBody = document.querySelector("#inventoryTable tbody")
tableBody.innerHTML=""

data.forEach(item=>{

let stock = item.stock_physical || 0
let reorder = item.reorder_point || 0
let eoq = item.EOQ || 0
let suggested = item.qty_suggested || 0

let status="OK"
let className="status-ok"

if(stock < reorder){

status="RUPTURE / COMMANDER"
className="status-risk"
rupture++
commandes++

}
else if(stock > eoq*2){

status="SURSTOCK"
className="status-surstock"
surstock++

}

const row = document.createElement("tr")

row.innerHTML = `
<td>${item.sku}</td>
<td>${item.description}</td>
<td>${item.category}</td>
<td>${stock}</td>
<td>${reorder}</td>
<td>${eoq}</td>
<td class="${className}">${status}</td>
<td>${suggested}</td>
`

tableBody.appendChild(row)

})

document.getElementById("totalSKU").innerText=data.length
document.getElementById("rupture").innerText=rupture
document.getElementById("surstock").innerText=surstock
document.getElementById("commandes").innerText=commandes

}

</script>

</body>
</html>
